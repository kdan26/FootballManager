@model FootballManager.ViewModels.TrainingSessionDetailViewModel
@using FootballManager.Models
@{
    ViewData["Title"] = Model.Title;
    bool canEdit = User.IsInRole("Admin") || User.IsInRole("Coach");
}

<div class="d-flex align-items-center mb-3 gap-2">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left"></i>
    </a>
    <span class="fs-5 fw-semibold">
        <i class="bi bi-journal-check me-2 text-success"></i>@Model.Title
    </span>
    <span class="badge @Model.StatusBadge ms-1">@Model.StatusLabel</span>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row g-4">
    <div class="col-lg-8">

        @* Thông tin chính *@
        <div class="card mb-4">
            <div class="card-header fw-semibold">
                <i class="bi bi-info-circle me-2"></i>Thông tin buổi tập
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-4">
                        <div class="text-muted small">Đội bóng</div>
                        <div class="fw-semibold">@Model.TeamName</div>
                    </div>
                    <div class="col-md-4">
                        <div class="text-muted small">Thời gian</div>
                        <div class="fw-semibold">@Model.ScheduledAt.ToString("HH:mm — dd/MM/yyyy")</div>
                    </div>
                    <div class="col-md-4">
                        <div class="text-muted small">Địa điểm</div>
                        <div class="fw-semibold">@(Model.Location ?? "Chưa xác định")</div>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.CoachNotes))
                    {
                        <div class="col-12">
                            <div class="text-muted small">Ghi chú HLV</div>
                            <div class="border rounded p-2 bg-light" style="white-space:pre-line">@Model.CoachNotes</div>
                        </div>
                    }
                </div>
            </div>
        </div>

        @* Danh sách bài tập *@
        <div class="card">
            <div class="card-header fw-semibold d-flex justify-content-between align-items-center">
                <span><i class="bi bi-collection-play me-2 text-success"></i>Bài tập trong buổi</span>
                <span class="badge bg-secondary">@Model.Drills.Count bài</span>
            </div>
            <div class="card-body p-0">
                @if (!Model.Drills.Any())
                {
                    <p class="text-muted p-3 mb-0">Chưa có bài tập nào.</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-sm table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th style="width:40px">STT</th>
                                    <th>Bài tập</th>
                                    <th>Loại</th>
                                    <th class="text-center">Thời lượng</th>
                                    <th>Ghi chú</th>
                                    @if (canEdit) { <th></th> }
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var d in Model.Drills)
                                {
                                    <tr>
                                        <td class="text-muted">@(d.OrderIndex + 1)</td>
                                        <td>
                                            <a asp-controller="Drill" asp-action="Details" asp-route-id="@d.DrillId"
                                               class="fw-semibold text-decoration-none">@d.DrillName</a>
                                        </td>
                                        <td>
                                            <span class="badge @(d.CategoryLabel == "Thể lực" ? "bg-danger" : d.CategoryLabel == "Kỹ thuật" ? "bg-primary" : "bg-warning text-dark") small">
                                                @d.CategoryLabel
                                            </span>
                                        </td>
                                        <td class="text-center small">
                                            @(d.ActualMinutes.HasValue ? $"{d.ActualMinutes} phút" : "—")
                                        </td>
                                        <td class="small text-muted">@d.Notes</td>
                                        @if (canEdit)
                                        {
                                            <td>
                                                <form asp-action="RemoveDrill" method="post"
                                                      onsubmit="return confirm('Xóa bài tập này khỏi buổi tập?')">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="sessionDrillId" value="@d.SessionDrillId" />
                                                    <input type="hidden" name="sessionId"      value="@Model.Id" />
                                                    <button type="submit" class="btn btn-xs btn-outline-danger py-0 px-1">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </form>
                                            </td>
                                        }
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card">
            <div class="card-header fw-semibold">Hành động</div>
            <div class="card-body d-flex flex-column gap-2">

                @* Điểm danh *@
                <a asp-controller="Calendar" asp-action="Attendance" asp-route-id="@Model.Id"
                   class="btn btn-outline-success btn-sm">
                    <i class="bi bi-clipboard-check me-2"></i>Điểm danh buổi tập
                </a>

                @if (canEdit)
                {
                    <a asp-action="Edit" asp-route-id="@Model.Id"
                       class="btn btn-outline-primary btn-sm">
                        <i class="bi bi-pencil me-2"></i>Chỉnh sửa
                    </a>

                    @if (Model.Status == TrainingSessionStatus.Scheduled)
                    {
                        <form asp-action="Complete" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.Id" />
                            <button type="submit" class="btn btn-success btn-sm w-100">
                                <i class="bi bi-check-circle me-2"></i>Đánh dấu hoàn thành
                            </button>
                        </form>
                        <form asp-action="Cancel" method="post"
                              onsubmit="return confirm('Hủy buổi tập này?')">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.Id" />
                            <button type="submit" class="btn btn-outline-danger btn-sm w-100">
                                <i class="bi bi-x-circle me-2"></i>Hủy buổi tập
                            </button>
                        </form>
                    }

                    <form asp-action="Delete" method="post"
                          onsubmit="return confirm('Xóa buổi tập này vĩnh viễn?')">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button type="submit" class="btn btn-outline-danger btn-sm w-100">
                            <i class="bi bi-trash me-2"></i>Xóa
                        </button>
                    </form>
                }
            </div>
        </div>
    </div>
</div>
