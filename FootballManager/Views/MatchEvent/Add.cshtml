@model FootballManager.ViewModels.AddMatchEventViewModel
@using FootballManager.Models
@{
    ViewData["Title"] = "Thêm sự kiện";
}

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card">
            <div class="card-header bg-warning text-dark">
                <i class="bi bi-lightning-charge me-2"></i>Thêm sự kiện — @Model.HomeTeamName vs @Model.AwayTeamName
            </div>
            <div class="card-body">
                <form asp-action="Add" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="MatchId" />
                    <input type="hidden" asp-for="HomeTeamName" />
                    <input type="hidden" asp-for="AwayTeamName" />

                    <div asp-validation-summary="All" class="alert alert-danger py-2"
                         style="display:@(ViewData.ModelState.IsValid ? "none" : "block")"></div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="EventType" class="form-label fw-semibold"></label>
                            <select asp-for="EventType" class="form-select" id="eventTypeSelect">
                                <option value="">-- Chọn loại sự kiện --</option>
                                <option value="Goal">⚽ Bàn thắng</option>
                                <option value="OwnGoal">🥅 Phản lưới</option>
                                <option value="YellowCard">🟨 Thẻ vàng</option>
                                <option value="RedCard">🟥 Thẻ đỏ</option>
                                <option value="Substitution">🔄 Thay người</option>
                                <option value="Penalty">⚽ Phạt đền</option>
                                <option value="MissedPenalty">❌ Phạt đền hỏng</option>
                            </select>
                            <span asp-validation-for="EventType" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Minute" class="form-label fw-semibold"></label>
                            <div class="input-group">
                                <input asp-for="Minute" type="number" min="1" max="120" class="form-control" placeholder="1-120" />
                                <span class="input-group-text">'</span>
                            </div>
                            <span asp-validation-for="Minute" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="PlayerId" class="form-label fw-semibold"></label>
                        <select asp-for="PlayerId" class="form-select">
                            <option value="">-- Chọn cầu thủ --</option>
                            <optgroup label="@Model.HomeTeamName">
                                @foreach (var p in Model.HomePlayers)
                                {
                                    <option value="@p.Value">@p.Text</option>
                                }
                            </optgroup>
                            <optgroup label="@Model.AwayTeamName">
                                @foreach (var p in Model.AwayPlayers)
                                {
                                    <option value="@p.Value">@p.Text</option>
                                }
                            </optgroup>
                        </select>
                        <span asp-validation-for="PlayerId" class="text-danger small"></span>
                    </div>

                    <div class="mb-3" id="substituteGroup" style="display:none">
                        <label asp-for="SubstitutePlayerId" class="form-label fw-semibold"></label>
                        <select asp-for="SubstitutePlayerId" class="form-select">
                            <option value="">-- Cầu thủ vào sân --</option>
                            <optgroup label="@Model.HomeTeamName">
                                @foreach (var p in Model.HomePlayers)
                                {
                                    <option value="@p.Value">@p.Text</option>
                                }
                            </optgroup>
                            <optgroup label="@Model.AwayTeamName">
                                @foreach (var p in Model.AwayPlayers)
                                {
                                    <option value="@p.Value">@p.Text</option>
                                }
                            </optgroup>
                        </select>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Description" class="form-label fw-semibold"></label>
                        <input asp-for="Description" class="form-control" placeholder="Mô tả thêm (tùy chọn)" />
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-warning">
                            <i class="bi bi-check-circle me-1"></i>Lưu sự kiện
                        </button>
                        <a asp-action="Index" asp-route-matchId="@Model.MatchId" class="btn btn-outline-secondary">Hủy</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
    <script>
        document.getElementById('eventTypeSelect').addEventListener('change', function () {
            var subGroup = document.getElementById('substituteGroup');
            subGroup.style.display = this.value === 'Substitution' ? 'block' : 'none';
        });
    </script>
}
