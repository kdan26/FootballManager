@model FootballManager.ViewModels.DrillDetailViewModel
@{
    ViewData["Title"] = Model.Name;
    string headerColor = Model.Category switch
    {
        FootballManager.Models.TrainingCategory.Physical  => "bg-danger",
        FootballManager.Models.TrainingCategory.Technical => "bg-primary",
        FootballManager.Models.TrainingCategory.Tactical  => "bg-warning text-dark",
        _ => "bg-secondary"
    };
}

<div class="d-flex align-items-center mb-3 gap-2">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left"></i>
    </a>
    <span class="fs-5 fw-semibold">
        <i class="bi bi-collection-play me-2 text-success"></i>Chi tiết bài tập
    </span>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row g-4">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header @headerColor d-flex justify-content-between align-items-center">
                <span class="fw-semibold">@Model.Name</span>
                <span class="badge bg-white bg-opacity-25">@Model.CategoryLabel</span>
            </div>
            <div class="card-body">

                @if (!string.IsNullOrEmpty(Model.Description))
                {
                    <p class="lead text-muted mb-4">@Model.Description</p>
                }

                @if (!string.IsNullOrEmpty(Model.Instructions))
                {
                    <h6 class="fw-semibold border-bottom pb-2 mb-3">
                        <i class="bi bi-list-ol me-2"></i>Hướng dẫn thực hiện
                    </h6>
                    <div class="mb-4" style="white-space: pre-line">@Model.Instructions</div>
                }

                @if (!string.IsNullOrEmpty(Model.VideoUrl))
                {
                    <h6 class="fw-semibold border-bottom pb-2 mb-3">
                        <i class="bi bi-play-circle me-2 text-danger"></i>Video minh hoạ
                    </h6>
                    <a href="@Model.VideoUrl" target="_blank" class="btn btn-outline-danger btn-sm mb-4">
                        <i class="bi bi-youtube me-2"></i>Xem video
                    </a>
                }

            </div>
        </div>
    </div>

    <div class="col-lg-4">
        @* Thông tin tóm tắt *@
        <div class="card mb-3">
            <div class="card-header fw-semibold">
                <i class="bi bi-info-circle me-2"></i>Thông tin
            </div>
            <div class="card-body">
                <table class="table table-sm table-borderless mb-0">
                    <tr>
                        <td class="text-muted small">Loại</td>
                        <td class="fw-semibold">@Model.CategoryLabel</td>
                    </tr>
                    <tr>
                        <td class="text-muted small">Độ khó</td>
                        <td>@Model.DifficultyLabel</td>
                    </tr>
                    @if (Model.DurationMinutes.HasValue)
                    {
                        <tr>
                            <td class="text-muted small">Thời lượng</td>
                            <td>@Model.DurationMinutes phút</td>
                        </tr>
                    }
                    <tr>
                        <td class="text-muted small">Chia sẻ</td>
                        <td>
                            @if (Model.IsShared)
                            {
                                <span class="badge bg-info-subtle text-info border border-info-subtle">
                                    <i class="bi bi-share me-1"></i>Tất cả HLV
                                </span>
                            }
                            else
                            {
                                <span class="text-muted small">Riêng tư</span>
                            }
                        </td>
                    </tr>
                    <tr>
                        <td class="text-muted small">Đã dùng</td>
                        <td class="fw-bold">@Model.UsageCount lần</td>
                    </tr>
                    <tr>
                        <td class="text-muted small">Tạo bởi</td>
                        <td>@Model.CreatedByName</td>
                    </tr>
                    <tr>
                        <td class="text-muted small">Cập nhật</td>
                        <td class="small">@Model.UpdatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                    </tr>
                </table>
            </div>
        </div>

        @* Hành động *@
        @if (User.IsInRole("Admin") || User.IsInRole("Coach"))
        {
            <div class="card">
                <div class="card-body d-flex flex-column gap-2">
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary btn-sm">
                        <i class="bi bi-pencil me-2"></i>Chỉnh sửa
                    </a>
                    <form asp-action="ToggleActive" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button type="submit" class="btn btn-sm w-100
                            @(Model.IsActive ? "btn-outline-danger" : "btn-outline-success")"
                            onclick="return confirm('@(Model.IsActive ? "Ẩn" : "Bật lại") bài tập này?')">
                            <i class="bi @(Model.IsActive ? "bi-eye-slash" : "bi-eye") me-2"></i>
                            @(Model.IsActive ? "Ẩn bài tập" : "Bật lại")
                        </button>
                    </form>
                </div>
            </div>
        }
    </div>
</div>
