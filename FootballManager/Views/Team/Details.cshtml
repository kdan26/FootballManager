@model FootballManager.ViewModels.TeamDetailsViewModel
@using FootballManager.Models
@{
    ViewData["Title"] = Model.Name;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4><i class="bi bi-shield-fill me-2 text-success"></i>@Model.Name</h4>
    <div class="d-flex gap-2">
        @if (User.IsInRole("Admin"))
        {
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary btn-sm">
                <i class="bi bi-pencil me-1"></i>Sửa
            </a>
            <form asp-action="Delete" asp-route-id="@Model.Id" method="post"
                  onsubmit="return confirm('Xóa đội \'@Model.Name\'?\n\nHành động này sẽ xóa TOÀN BỘ:\n• @Model.Matches.Count trận đấu\n• Tất cả cầu thủ và dữ liệu liên quan\n• Lịch tập, điểm danh, chỉ số\n\nKhông thể hoàn tác!')">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-outline-danger btn-sm">
                    <i class="bi bi-trash me-1"></i>Xóa đội
                </button>
            </form>
        }
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i>Quay lại
        </a>
    </div>
</div>

<div class="card mb-4">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Sân nhà</dt>
            <dd class="col-sm-9">@Model.HomeGround</dd>
            @if (!string.IsNullOrEmpty(Model.Description))
            {
                <dt class="col-sm-3">Mô tả</dt>
                <dd class="col-sm-9">@Model.Description</dd>
            }
        </dl>
    </div>
</div>

<div class="mb-4">
    <a asp-controller="Player" asp-action="Index" asp-route-teamId="@Model.Id"
       class="btn btn-outline-success">
        <i class="bi bi-people me-1"></i>Xem cầu thủ
    </a>
    @if (User.IsInRole("Admin") || User.IsInRole("Coach"))
    {
        <a asp-controller="Player" asp-action="Create" asp-route-teamId="@Model.Id"
           class="btn btn-success ms-2">
            <i class="bi bi-person-plus me-1"></i>Thêm cầu thủ
        </a>
        <a asp-controller="PlayerStats" asp-action="TacticalBoard" asp-route-teamId="@Model.Id"
           class="btn btn-outline-primary ms-2">
            <i class="bi bi-diagram-3 me-1"></i>Bảng chiến thuật
        </a>
    }
</div>

<h5 class="mb-3"><i class="bi bi-calendar-event me-2"></i>Lịch sử trận đấu (@Model.Matches.Count)</h5>

@if (!Model.Matches.Any())
{
    <p class="text-muted">Chưa có trận đấu nào.</p>
}
else
{
    <div class="table-responsive">
        <table class="table table-sm table-hover">
            <thead class="table-light">
                <tr>
                    <th>Đội nhà</th>
                    <th>Đội khách</th>
                    <th>Ngày</th>
                    <th>Địa điểm</th>
                    <th class="text-center">Kết quả</th>
                    <th class="text-center">Trạng thái</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var m in Model.Matches)
                {
                    <tr>
                        <td>@m.HomeTeamName</td>
                        <td>@m.AwayTeamName</td>
                        <td>@m.MatchDate.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>@(m.Venue ?? "-")</td>
                        <td class="text-center">
                            @if (m.Status == MatchStatus.Completed)
                            {
                                <strong>@m.HomeScore - @m.AwayScore</strong>
                            }
                            else { <span>-</span> }
                        </td>
                        <td class="text-center">
                            @{
                                var badge = m.Status switch
                                {
                                    MatchStatus.Scheduled => "bg-primary",
                                    MatchStatus.Completed => "bg-success",
                                    MatchStatus.Cancelled => "bg-secondary",
                                    _ => "bg-secondary"
                                };
                                var label = m.Status switch
                                {
                                    MatchStatus.Scheduled => "Sắp diễn ra",
                                    MatchStatus.Completed => "Đã kết thúc",
                                    MatchStatus.Cancelled => "Đã hủy",
                                    _ => ""
                                };
                            }
                            <span class="badge @badge">@label</span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
