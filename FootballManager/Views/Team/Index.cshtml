@model IEnumerable<FootballManager.ViewModels.TeamListItemViewModel>
@{
    ViewData["Title"] = "Đội bóng";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4><i class="bi bi-people-fill me-2 text-success"></i>Danh sách đội bóng</h4>
    @if (User.IsInRole("Admin"))
    {
        <a asp-action="Create" class="btn btn-success">
            <i class="bi bi-plus-circle me-1"></i>Thêm đội mới
        </a>
    }
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (!Model.Any())
{
    <div class="text-center py-5 text-muted">
        <i class="bi bi-people fs-1"></i>
        <p class="mt-2">Chưa có đội bóng nào</p>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-success">
                <tr>
                    <th>Tên đội</th>
                    <th>Sân nhà</th>
                    <th class="text-center">Số trận</th>
                    <th class="text-end">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var team in Model)
                {
                    <tr>
                        <td class="fw-semibold">@team.Name</td>
                        <td>@team.HomeGround</td>
                        <td class="text-center">
                            <span class="badge bg-secondary">@team.MatchCount</span>
                        </td>
                        <td class="text-end">
                            <a asp-action="Details" asp-route-id="@team.Id" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-eye"></i>
                            </a>
                            @if (User.IsInRole("Admin"))
                            {
                                <a asp-action="Edit" asp-route-id="@team.Id" class="btn btn-sm btn-outline-warning ms-1">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <form asp-action="Delete" asp-route-id="@team.Id" method="post" class="d-inline ms-1"
                                      onsubmit="return confirm('Bạn có chắc muốn xóa đội @team.Name?')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
