@model FootballManager.ViewModels.PlayerStatsViewModel
@{
    ViewData["Title"] = "Thống kê cầu thủ";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4><i class="bi bi-bar-chart-fill me-2 text-success"></i>Thống kê cầu thủ</h4>
    <form method="get" class="d-flex gap-2">
        <select name="team" class="form-select form-select-sm" style="width:200px"
                onchange="this.form.submit()">
            <option value="">-- Tất cả đội --</option>
            @foreach (var t in Model.Teams)
            {
                if (Model.TeamFilter == t)
                {
                    <option value="@t" selected="selected">@t</option>
                }
                else
                {
                    <option value="@t">@t</option>
                }
            }
        </select>
    </form>
</div>

<div class="row g-4">
    @* Vua phá lưới *@
    <div class="col-lg-6">
        <div class="card h-100">
            <div class="card-header bg-success text-white">
                <i class="bi bi-trophy-fill me-2"></i>Vua phá lưới
            </div>
            <div class="card-body p-0">
                @if (!Model.TopScorers.Any())
                {
                    <p class="text-muted p-3 mb-0">Chưa có dữ liệu</p>
                }
                else
                {
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>#</th>
                                <th>Cầu thủ</th>
                                <th>Đội</th>
                                <th class="text-center">⚽</th>
                                <th class="text-center">Phạt đền</th>
                            </tr>
                        </thead>
                        <tbody>
                            @for (int i = 0; i < Model.TopScorers.Count; i++)
                            {
                                var p = Model.TopScorers[i];
                                <tr>
                                    <td>
                                        @if (i == 0)
                                        {
                                            <span class="badge bg-warning text-dark">🥇</span>
                                        }
                                        else if (i == 1)
                                        {
                                            <span class="badge bg-secondary">🥈</span>
                                        }
                                        else if (i == 2)
                                        {
                                            <span class="badge bg-danger">🥉</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">@(i + 1)</span>
                                        }
                                    </td>
                                    <td>
                                        <a asp-action="Player" asp-route-id="@p.PlayerId">@p.FullName</a>
                                        <span class="text-muted small">#@p.JerseyNumber</span>
                                    </td>
                                    <td class="text-muted small">@p.TeamName</td>
                                    <td class="text-center fw-bold">@p.Goals</td>
                                    <td class="text-center">@p.Penalties</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>

    @* Thẻ phạt *@
    <div class="col-lg-6">
        <div class="card mb-3">
            <div class="card-header bg-warning text-dark">
                <i class="bi bi-square-fill me-2"></i>Thẻ vàng nhiều nhất
            </div>
            <div class="card-body p-0">
                @if (!Model.MostYellowCards.Any())
                {
                    <p class="text-muted p-3 mb-0">Chưa có dữ liệu</p>
                }
                else
                {
                    <table class="table table-hover mb-0 table-sm">
                        <thead class="table-light">
                            <tr>
                                <th>Cầu thủ</th>
                                <th>Đội</th>
                                <th class="text-center">🟨</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var p in Model.MostYellowCards)
                            {
                                <tr>
                                    <td><a asp-action="Player" asp-route-id="@p.PlayerId">@p.FullName</a></td>
                                    <td class="text-muted small">@p.TeamName</td>
                                    <td class="text-center fw-bold">@p.YellowCards</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>

        <div class="card">
            <div class="card-header bg-danger text-white">
                <i class="bi bi-square-fill me-2"></i>Thẻ đỏ nhiều nhất
            </div>
            <div class="card-body p-0">
                @if (!Model.MostRedCards.Any())
                {
                    <p class="text-muted p-3 mb-0">Chưa có dữ liệu</p>
                }
                else
                {
                    <table class="table table-hover mb-0 table-sm">
                        <thead class="table-light">
                            <tr>
                                <th>Cầu thủ</th>
                                <th>Đội</th>
                                <th class="text-center">🟥</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var p in Model.MostRedCards)
                            {
                                <tr>
                                    <td><a asp-action="Player" asp-route-id="@p.PlayerId">@p.FullName</a></td>
                                    <td class="text-muted small">@p.TeamName</td>
                                    <td class="text-center fw-bold">@p.RedCards</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>

    @* Bảng tổng hợp *@
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <i class="bi bi-table me-2"></i>Bảng thống kê tổng hợp
            </div>
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Cầu thủ</th>
                            <th>Đội</th>
                            <th>Vị trí</th>
                            <th class="text-center">Trận</th>
                            <th class="text-center">⚽ Bàn</th>
                            <th class="text-center">Phạt đền</th>
                            <th class="text-center">Phản lưới</th>
                            <th class="text-center">🟨</th>
                            <th class="text-center">🟥</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.AllStats.Any())
                        {
                            <tr>
                                <td colspan="9" class="text-center text-muted py-3">Chưa có dữ liệu thống kê</td>
                            </tr>
                        }
                        @foreach (var p in Model.AllStats)
                        {
                            <tr>
                                <td>
                                    <a asp-action="Player" asp-route-id="@p.PlayerId" class="fw-semibold">
                                        @p.FullName
                                    </a>
                                    <span class="text-muted small">#@p.JerseyNumber</span>
                                </td>
                                <td class="text-muted small">@p.TeamName</td>
                                <td class="text-muted small">@p.PositionLabel</td>
                                <td class="text-center">@p.MatchesPlayed</td>
                                <td class="text-center fw-bold text-success">@p.Goals</td>
                                <td class="text-center">@p.Penalties</td>
                                <td class="text-center text-danger">@p.OwnGoals</td>
                                <td class="text-center">@p.YellowCards</td>
                                <td class="text-center">@p.RedCards</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
