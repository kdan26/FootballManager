@model FootballManager.ViewModels.PlayerCreateViewModel
@using FootballManager.Models
@{
    ViewData["Title"] = "Thêm cầu thủ";
}

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card">
            <div class="card-header bg-success text-white">
                <i class="bi bi-person-plus me-2"></i>Thêm cầu thủ — @Model.TeamName
            </div>
            <div class="card-body">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="TeamId" />
                    <input type="hidden" asp-for="TeamName" />

                    <div asp-validation-summary="All" class="alert alert-danger py-2"
                         style="display:@(ViewData.ModelState.IsValid ? "none" : "block")"></div>

                    <div class="row mb-3">
                        <div class="col-md-8">
                            <label asp-for="FullName" class="form-label fw-semibold"></label>
                            <input asp-for="FullName" class="form-control" placeholder="Họ và tên cầu thủ" autofocus />
                            <span asp-validation-for="FullName" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="JerseyNumber" class="form-label fw-semibold"></label>
                            <input asp-for="JerseyNumber" type="number" min="1" max="99" class="form-control" placeholder="1-99" />
                            <span asp-validation-for="JerseyNumber" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="Position" class="form-label fw-semibold"></label>
                            <select asp-for="Position" class="form-select">
                                <option value="GoalKeeper">Thủ môn</option>
                                <option value="CenterBack">Trung vệ</option>
                                <option value="FullBack">Hậu vệ biên</option>
                                <option value="DefensiveMid">Tiền vệ phòng ngự</option>
                                <option value="CentralMid" selected>Tiền vệ trung tâm</option>
                                <option value="AttackingMid">Tiền vệ công</option>
                                <option value="Winger">Chạy cánh</option>
                                <option value="Striker">Tiền đạo</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="DateOfBirth" class="form-label fw-semibold"></label>
                            <input asp-for="DateOfBirth" type="date" class="form-control" />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Nationality" class="form-label fw-semibold"></label>
                        <input asp-for="Nationality" class="form-control" placeholder="VD: Việt Nam" />
                    </div>

                    <div class="mb-3">
                        <label asp-for="Notes" class="form-label fw-semibold"></label>
                        <textarea asp-for="Notes" class="form-control" rows="2"></textarea>
                    </div>

                    <div class="mb-4 form-check">
                        <input asp-for="IsActive" class="form-check-input" />
                        <label asp-for="IsActive" class="form-check-label">Đang hoạt động</label>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-success">
                            <i class="bi bi-check-circle me-1"></i>Lưu
                        </button>
                        <a asp-action="Index" asp-route-teamId="@Model.TeamId" class="btn btn-outline-secondary">Hủy</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
