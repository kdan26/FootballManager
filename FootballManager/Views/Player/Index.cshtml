@model IEnumerable<FootballManager.ViewModels.PlayerListItemViewModel>
@using FootballManager.Models
@{
    ViewData["Title"] = $"Cầu thủ - {ViewBag.TeamName}";
    int teamId = ViewBag.TeamId;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <a asp-controller="Team" asp-action="Details" asp-route-id="@teamId"
           class="btn btn-outline-secondary btn-sm me-2">
            <i class="bi bi-arrow-left"></i>
        </a>
        <span class="fs-5 fw-semibold">
            <i class="bi bi-person-badge me-2 text-success"></i>Cầu thủ — @ViewBag.TeamName
        </span>
    </div>
    @if (User.IsInRole("Admin") || User.IsInRole("Coach"))
    {
        <a asp-action="Create" asp-route-teamId="@teamId" class="btn btn-success">
            <i class="bi bi-person-plus me-1"></i>Thêm cầu thủ
        </a>
    }
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (!Model.Any())
{
    <div class="text-center py-5 text-muted">
        <i class="bi bi-person-x fs-1"></i>
        <p class="mt-2">Chưa có cầu thủ nào trong đội</p>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var p in Model)
        {
            <div class="col-sm-6 col-lg-4">
                <div class="card h-100 @(p.IsActive ? "" : "opacity-50")">
                    <div class="card-body d-flex align-items-center gap-3">
                        <div class="bg-success text-white rounded-circle d-flex align-items-center justify-content-center fw-bold"
                             style="width:50px;height:50px;font-size:1.2rem;flex-shrink:0">
                            @(p.JerseyNumber?.ToString() ?? "?")
                        </div>
                        <div class="flex-grow-1">
                            <div class="fw-semibold">@p.FullName</div>
                            <div class="text-muted small">@p.PositionLabel</div>
                            @if (!p.IsActive)
                            {
                                <span class="badge bg-secondary">Không hoạt động</span>
                            }
                        </div>
                        <div class="d-flex flex-column gap-1">
                            <a asp-action="Details" asp-route-id="@p.Id"
                               class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-eye"></i>
                            </a>
                            @if (User.IsInRole("Admin") || User.IsInRole("Coach"))
                            {
                                <a asp-action="Edit" asp-route-id="@p.Id"
                                   class="btn btn-sm btn-outline-warning">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <form asp-action="Delete" asp-route-id="@p.Id" method="post"
                                      onsubmit="return confirm('Xóa cầu thủ @p.FullName?')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
