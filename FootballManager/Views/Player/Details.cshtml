@model FootballManager.ViewModels.PlayerDetailsViewModel
@{
    ViewData["Title"] = Model.FullName;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4><i class="bi bi-person-badge me-2 text-success"></i>@Model.FullName</h4>
    <a asp-action="Index" asp-route-teamId="@Model.TeamId" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Quay lại
    </a>
</div>

<div class="card">
    <div class="card-body">
        <div class="d-flex align-items-center gap-4 mb-4">
            <div class="bg-success text-white rounded-circle d-flex align-items-center justify-content-center fw-bold"
                 style="width:80px;height:80px;font-size:2rem;flex-shrink:0">
                @(Model.JerseyNumber?.ToString() ?? "?")
            </div>
            <div>
                <h5 class="mb-1">@Model.FullName</h5>
                <span class="badge bg-success">@Model.PositionLabel</span>
                @if (!Model.IsActive)
                {
                    <span class="badge bg-secondary ms-1">Không hoạt động</span>
                }
            </div>
        </div>

        <dl class="row">
            <dt class="col-sm-3">Đội bóng</dt>
            <dd class="col-sm-9">
                <a asp-controller="Team" asp-action="Details" asp-route-id="@Model.TeamId">
                    @Model.TeamName
                </a>
            </dd>

            <dt class="col-sm-3">Số áo</dt>
            <dd class="col-sm-9">@(Model.JerseyNumber?.ToString() ?? "-")</dd>

            <dt class="col-sm-3">Vị trí</dt>
            <dd class="col-sm-9">@Model.PositionLabel</dd>

            @if (Model.DateOfBirth.HasValue)
            {
                <dt class="col-sm-3">Ngày sinh</dt>
                <dd class="col-sm-9">
                    @Model.DateOfBirth.Value.ToString("dd/MM/yyyy")
                    @if (Model.Age.HasValue)
                    {
                        <span class="text-muted">(@Model.Age tuổi)</span>
                    }
                </dd>
            }

            @if (!string.IsNullOrEmpty(Model.Nationality))
            {
                <dt class="col-sm-3">Quốc tịch</dt>
                <dd class="col-sm-9">@Model.Nationality</dd>
            }

            @if (!string.IsNullOrEmpty(Model.Notes))
            {
                <dt class="col-sm-3">Ghi chú</dt>
                <dd class="col-sm-9">@Model.Notes</dd>
            }
        </dl>

        @if (User.IsInRole("Admin") || User.IsInRole("Coach"))
        {
            <div class="mt-3 d-flex gap-2">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning btn-sm">
                    <i class="bi bi-pencil me-1"></i>Chỉnh sửa
                </a>
                <a asp-controller="PlayerStats" asp-action="Index" asp-route-playerId="@Model.Id"
                   class="btn btn-outline-primary btn-sm">
                    <i class="bi bi-graph-up me-1"></i>Xem chỉ số
                </a>
                <a asp-controller="Stats" asp-action="Player" asp-route-id="@Model.Id"
                   class="btn btn-outline-success btn-sm">
                    <i class="bi bi-bar-chart me-1"></i>Xem thống kê
                </a>
            </div>
        }
        else
        {
            <div class="mt-3 d-flex gap-2">
                <a asp-controller="PlayerStats" asp-action="Index" asp-route-playerId="@Model.Id"
                   class="btn btn-outline-primary btn-sm">
                    <i class="bi bi-graph-up me-1"></i>Xem chỉ số
                </a>
                <a asp-controller="Stats" asp-action="Player" asp-route-id="@Model.Id"
                   class="btn btn-outline-success btn-sm">
                    <i class="bi bi-bar-chart me-1"></i>Xem thống kê
                </a>
            </div>
        }
    </div>
</div>
