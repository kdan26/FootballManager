@model FootballManager.ViewModels.DashboardViewModel
@using FootballManager.Models
@{
    ViewData["Title"] = "Tổng quan";
}

<h4 class="mb-4"><i class="bi bi-speedometer2 me-2 text-success"></i>Tổng quan</h4>

<div class="row g-3 mb-4">
    <div class="col-sm-6 col-lg-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="bg-success bg-opacity-10 rounded-3 p-3">
                    <i class="bi bi-people-fill fs-3 text-success"></i>
                </div>
                <div>
                    <div class="fs-2 fw-bold">@Model.TotalTeams</div>
                    <div class="text-muted small">Tổng số đội</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-lg-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="bg-primary bg-opacity-10 rounded-3 p-3">
                    <i class="bi bi-calendar-event fs-3 text-primary"></i>
                </div>
                <div>
                    <div class="fs-2 fw-bold">@Model.TotalMatches</div>
                    <div class="text-muted small">Tổng số trận</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-lg-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="bg-warning bg-opacity-10 rounded-3 p-3">
                    <i class="bi bi-trophy-fill fs-3 text-warning"></i>
                </div>
                <div>
                    <div class="fs-2 fw-bold">@Model.CompletedMatches</div>
                    <div class="text-muted small">Trận đã kết thúc</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-lg-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="bg-info bg-opacity-10 rounded-3 p-3">
                    <i class="bi bi-clock-fill fs-3 text-info"></i>
                </div>
                <div>
                    <div class="fs-2 fw-bold">@Model.UpcomingMatchCount</div>
                    <div class="text-muted small">Trận sắp diễn ra</div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-header bg-white border-bottom">
        <h6 class="mb-0"><i class="bi bi-calendar-week me-2 text-success"></i>Trận đấu sắp diễn ra</h6>
    </div>
    <div class="card-body p-0">
        @if (!Model.UpcomingMatches.Any())
        {
            <div class="text-center py-4 text-muted">
                <i class="bi bi-calendar-check fs-3"></i>
                <p class="mt-2 mb-0">Không có trận đấu nào sắp diễn ra</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Đội nhà</th>
                            <th class="text-center">vs</th>
                            <th>Đội khách</th>
                            <th>Ngày thi đấu</th>
                            <th>Địa điểm</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var m in Model.UpcomingMatches)
                        {
                            <tr>
                                <td class="fw-semibold">@m.HomeTeamName</td>
                                <td class="text-center text-muted">vs</td>
                                <td class="fw-semibold">@m.AwayTeamName</td>
                                <td>@m.MatchDate.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>@(m.Venue ?? "-")</td>
                                <td>
                                    <a asp-controller="Match" asp-action="Details" asp-route-id="@m.Id"
                                       class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
