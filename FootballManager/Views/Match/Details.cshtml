@model FootballManager.ViewModels.MatchDetailsViewModel
@using FootballManager.Models
@{
    ViewData["Title"] = $"{Model.HomeTeamName} vs {Model.AwayTeamName}";
    var badge = Model.Status switch
    {
        MatchStatus.Scheduled => "bg-primary",
        MatchStatus.Completed => "bg-success",
        MatchStatus.Cancelled => "bg-secondary",
        _ => "bg-secondary"
    };
    var label = Model.Status switch
    {
        MatchStatus.Scheduled => "Sắp diễn ra",
        MatchStatus.Completed => "Đã kết thúc",
        MatchStatus.Cancelled => "Đã hủy",
        _ => ""
    };
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4><i class="bi bi-calendar-event me-2 text-success"></i>Chi tiết trận đấu</h4>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Quay lại
    </a>
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card mb-4">
    <div class="card-body">
        @if (Model.Status == MatchStatus.Completed)
        {
            <div class="text-center py-3">
                <div class="d-flex justify-content-center align-items-center gap-4">
                    <span class="fs-4 fw-bold">@Model.HomeTeamName</span>
                    <span class="display-4 fw-bold text-success">@Model.HomeScore - @Model.AwayScore</span>
                    <span class="fs-4 fw-bold">@Model.AwayTeamName</span>
                </div>
            </div>
        }
        else
        {
            <div class="text-center py-3">
                <div class="d-flex justify-content-center align-items-center gap-4">
                    <span class="fs-4 fw-bold">@Model.HomeTeamName</span>
                    <span class="fs-3 text-muted">vs</span>
                    <span class="fs-4 fw-bold">@Model.AwayTeamName</span>
                </div>
            </div>
        }

        <hr />

        <dl class="row mb-0">
            <dt class="col-sm-3">Ngày thi đấu</dt>
            <dd class="col-sm-9">@Model.MatchDate.ToString("dd/MM/yyyy HH:mm")</dd>

            <dt class="col-sm-3">Địa điểm</dt>
            <dd class="col-sm-9">@(Model.Venue ?? "-")</dd>

            <dt class="col-sm-3">Trạng thái</dt>
            <dd class="col-sm-9"><span class="badge @badge">@label</span></dd>

            @if (!string.IsNullOrEmpty(Model.Notes))
            {
                <dt class="col-sm-3">Ghi chú</dt>
                <dd class="col-sm-9">@Model.Notes</dd>
            }
        </dl>
    </div>
</div>

<div class="mb-3">
    <a asp-controller="MatchEvent" asp-action="Index" asp-route-matchId="@Model.Id"
       class="btn btn-outline-warning">
        <i class="bi bi-lightning-charge me-1"></i>Xem sự kiện trận đấu
    </a>
</div>

@if (Model.Status == MatchStatus.Scheduled)
{
    <div class="d-flex gap-2 flex-wrap">
        @if (User.IsInRole("Admin") || User.IsInRole("Coach"))
        {
            <a asp-action="UpdateResult" asp-route-id="@Model.Id" class="btn btn-success">
                <i class="bi bi-trophy me-1"></i>Cập nhật kết quả
            </a>
            <a asp-controller="Attendance" asp-action="Match"
               asp-route-id="@Model.Id" asp-route-teamId="@Model.HomeTeamId"
               class="btn btn-outline-info">
                <i class="bi bi-clipboard-check me-1"></i>Điểm danh (@Model.HomeTeamName)
            </a>
            <a asp-controller="Attendance" asp-action="Match"
               asp-route-id="@Model.Id" asp-route-teamId="@Model.AwayTeamId"
               class="btn btn-outline-info">
                <i class="bi bi-clipboard-check me-1"></i>Điểm danh (@Model.AwayTeamName)
            </a>
        }
        @if (User.IsInRole("Admin"))
        {
            <form asp-action="Cancel" asp-route-id="@Model.Id" method="post"
                  onsubmit="return confirm('Bạn có chắc muốn hủy trận đấu này?')">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-outline-danger">
                    <i class="bi bi-x-circle me-1"></i>Hủy trận
                </button>
            </form>
        }
    </div>
}
