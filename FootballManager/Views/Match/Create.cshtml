@model FootballManager.ViewModels.MatchCreateViewModel
@{
    ViewData["Title"] = "Lên lịch trận đấu";
}

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card">
            <div class="card-header bg-success text-white">
                <i class="bi bi-calendar-plus me-2"></i>Lên lịch trận đấu mới
            </div>
            <div class="card-body">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="All" class="alert alert-danger py-2"
                         style="display:@(ViewData.ModelState.IsValid ? "none" : "block")"></div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="HomeTeamId" class="form-label fw-semibold"></label>
                            <select asp-for="HomeTeamId" asp-items="Model.Teams" class="form-select">
                                <option value="0">-- Chọn đội nhà --</option>
                            </select>
                            <span asp-validation-for="HomeTeamId" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="AwayTeamId" class="form-label fw-semibold"></label>
                            <select asp-for="AwayTeamId" asp-items="Model.Teams" class="form-select">
                                <option value="0">-- Chọn đội khách --</option>
                            </select>
                            <span asp-validation-for="AwayTeamId" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="MatchDate" class="form-label fw-semibold"></label>
                        <input asp-for="MatchDate" type="datetime-local" class="form-control"
                               value="@Model.MatchDate.ToString("yyyy-MM-ddTHH:mm")" />
                        <span asp-validation-for="MatchDate" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Venue" class="form-label fw-semibold"></label>
                        <input asp-for="Venue" class="form-control" placeholder="Nhập địa điểm thi đấu" />
                        <span asp-validation-for="Venue" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Notes" class="form-label fw-semibold"></label>
                        <textarea asp-for="Notes" class="form-control" rows="3" placeholder="Ghi chú (tùy chọn)"></textarea>
                        <span asp-validation-for="Notes" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-success">
                            <i class="bi bi-check-circle me-1"></i>Lưu
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Hủy</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
