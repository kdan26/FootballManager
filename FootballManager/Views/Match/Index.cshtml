@model IEnumerable<FootballManager.ViewModels.MatchListItemViewModel>
@using FootballManager.Models
@{
    ViewData["Title"] = "Trận đấu";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4><i class="bi bi-calendar-event me-2 text-success"></i>Danh sách trận đấu</h4>
    @if (User.IsInRole("Admin") || User.IsInRole("Coach"))
    {
        <a asp-action="Create" class="btn btn-success">
            <i class="bi bi-plus-circle me-1"></i>Lên lịch trận mới
        </a>
    }
</div>

@if (!Model.Any())
{
    <div class="text-center py-5 text-muted">
        <i class="bi bi-calendar-x fs-1"></i>
        <p class="mt-2">Chưa có trận đấu nào được lên lịch</p>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-success">
                <tr>
                    <th>Đội nhà</th>
                    <th class="text-center">Kết quả</th>
                    <th>Đội khách</th>
                    <th>Ngày thi đấu</th>
                    <th>Địa điểm</th>
                    <th class="text-center">Trạng thái</th>
                    <th class="text-end">Chi tiết</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var m in Model)
                {
                    var badge = m.Status switch
                    {
                        MatchStatus.Scheduled => "bg-primary",
                        MatchStatus.Completed => "bg-success",
                        MatchStatus.Cancelled => "bg-secondary",
                        _ => "bg-secondary"
                    };
                    var label = m.Status switch
                    {
                        MatchStatus.Scheduled => "Sắp diễn ra",
                        MatchStatus.Completed => "Đã kết thúc",
                        MatchStatus.Cancelled => "Đã hủy",
                        _ => ""
                    };
                    <tr>
                        <td class="fw-semibold">@m.HomeTeamName</td>
                        <td class="text-center">
                            @if (m.Status == MatchStatus.Completed)
                            {
                                <span class="fw-bold fs-5">@m.HomeScore - @m.AwayScore</span>
                            }
                            else
                            {
                                <span class="text-muted">vs</span>
                            }
                        </td>
                        <td class="fw-semibold">@m.AwayTeamName</td>
                        <td>@m.MatchDate.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>@(m.Venue ?? "-")</td>
                        <td class="text-center"><span class="badge @badge">@label</span></td>
                        <td class="text-end">
                            <a asp-action="Details" asp-route-id="@m.Id" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-eye"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
