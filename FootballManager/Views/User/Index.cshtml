@model List<FootballManager.ViewModels.UserListItem>
@{
    ViewData["Title"] = "Quản lý tài khoản";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <span class="fs-5 fw-semibold">
        <i class="bi bi-people-fill me-2 text-primary"></i>Quản lý tài khoản
    </span>
    <a asp-action="Create" class="btn btn-primary btn-sm">
        <i class="bi bi-person-plus me-1"></i>Tạo tài khoản
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        <i class="bi bi-exclamation-triangle me-2"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@* Thống kê nhanh *@
<div class="row g-3 mb-4">
    @foreach (var grp in Model.GroupBy(u => u.Role).OrderBy(g => g.Key))
    {
        var first = grp.First();
        <div class="col-6 col-md-2">
            <div class="card text-center border-0 shadow-sm">
                <div class="card-body py-2">
                    <div class="fs-4 fw-bold">@grp.Count()</div>
                    <span class="badge @first.RoleBadge">@first.RoleLabel</span>
                </div>
            </div>
        </div>
    }
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Họ tên</th>
                        <th>Tên đăng nhập</th>
                        <th>Vai trò</th>
                        <th>Liên kết cầu thủ</th>
                        <th class="text-center">Trạng thái</th>
                        <th>Ngày tạo</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var u in Model)
                    {
                        <tr class="@(u.IsActive ? "" : "table-secondary text-muted")">
                            <td class="fw-semibold">@u.FullName</td>
                            <td class="small text-muted">@u.Username</td>
                            <td>
                                <span class="badge @u.RoleBadge">@u.RoleLabel</span>
                            </td>
                            <td class="small">
                                @if (!string.IsNullOrEmpty(u.PlayerName))
                                {
                                    <i class="bi bi-person-badge me-1 text-success"></i>@u.PlayerName
                                }
                                else { <span class="text-muted">—</span> }
                            </td>
                            <td class="text-center">
                                @if (u.IsActive)
                                {
                                    <span class="badge bg-success">Hoạt động</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Vô hiệu</span>
                                }
                            </td>
                            <td class="small text-muted">@u.CreatedAt.ToString("dd/MM/yyyy")</td>
                            <td>
                                <div class="d-flex gap-1">
                                    <a asp-action="Edit" asp-route-id="@u.Id"
                                       class="btn btn-xs btn-outline-primary py-0 px-2" title="Sửa">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a asp-action="ChangePassword" asp-route-id="@u.Id"
                                       class="btn btn-xs btn-outline-warning py-0 px-2" title="Đổi mật khẩu">
                                        <i class="bi bi-key"></i>
                                    </a>
                                    <form asp-action="Delete" method="post"
                                          onsubmit="return confirm('Xóa tài khoản @u.Username?')">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@u.Id" />
                                        <button type="submit"
                                                class="btn btn-xs btn-outline-danger py-0 px-2" title="Xóa">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
