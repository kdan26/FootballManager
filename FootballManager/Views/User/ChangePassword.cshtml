@model FootballManager.ViewModels.ChangePasswordViewModel
@{
    ViewData["Title"] = "Đổi mật khẩu";
}

<div class="d-flex align-items-center mb-3 gap-2">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i></a>
    <span class="fs-5 fw-semibold">
        <i class="bi bi-key me-2 text-warning"></i>Đổi mật khẩu — @Model.FullName
    </span>
</div>

<div class="row justify-content-center">
    <div class="col-lg-5">
        <div class="card">
            <div class="card-header bg-warning text-dark fw-semibold">Mật khẩu mới</div>
            <div class="card-body">
                <form asp-action="ChangePassword" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="UserId" />
                    <input type="hidden" asp-for="FullName" />

                    <div asp-validation-summary="All" class="alert alert-danger py-2"
                         style="display:@(ViewData.ModelState.IsValid ? "none" : "block")"></div>

                    <div class="mb-3">
                        <label asp-for="NewPassword" class="form-label fw-semibold"></label>
                        <input asp-for="NewPassword" type="password" class="form-control" />
                        <span asp-validation-for="NewPassword" class="text-danger small"></span>
                    </div>
                    <div class="mb-4">
                        <label asp-for="ConfirmPassword" class="form-label fw-semibold"></label>
                        <input asp-for="ConfirmPassword" type="password" class="form-control" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-warning">
                            <i class="bi bi-save me-1"></i>Lưu mật khẩu
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Hủy</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
