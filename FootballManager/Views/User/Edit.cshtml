@model FootballManager.ViewModels.UserEditViewModel
@{
    ViewData["Title"] = "Sửa tài khoản";
}

<div class="d-flex align-items-center mb-3 gap-2">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i></a>
    <span class="fs-5 fw-semibold"><i class="bi bi-person-gear me-2 text-primary"></i>Chỉnh sửa tài khoản</span>
</div>

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card">
            <div class="card-header bg-primary text-white">Cập nhật thông tin</div>
            <div class="card-body">
                <form asp-action="Edit" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />
                    <div asp-validation-summary="All" class="alert alert-danger py-2"
                         style="display:@(ViewData.ModelState.IsValid ? "none" : "block")"></div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="FullName" class="form-label fw-semibold"></label>
                            <input asp-for="FullName" class="form-control" />
                            <span asp-validation-for="FullName" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Role" class="form-label fw-semibold"></label>
                            <select asp-for="Role" class="form-select" id="roleSelect">
                                <option value="Admin">👑 Quản trị (Admin)</option>
                                <option value="Coach">🏋️ Huấn luyện viên (Coach)</option>
                                <option value="Analyst">📊 Chuyên viên phân tích (Analyst)</option>
                                <option value="Player">⚽ Cầu thủ (Player)</option>
                                <option value="Member">👁️ Thành viên (Member)</option>
                            </select>
                        </div>
                    </div>

                    <div id="playerSection" class="mb-3">
                        <label asp-for="PlayerId" class="form-label fw-semibold"></label>
                        <select asp-for="PlayerId" class="form-select">
                            <option value="">-- Không liên kết --</option>
                            @foreach (var p in Model.AvailablePlayers)
                            {
                                <option value="@p.Id">
                                    [@p.TeamName] #@(p.JerseyNumber?.ToString() ?? "?") @p.FullName
                                </option>
                            }
                        </select>
                    </div>

                    <div class="mb-3 form-check">
                        <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                        <label asp-for="IsActive" class="form-check-label fw-semibold">Tài khoản hoạt động</label>
                        <div class="form-text">Bỏ chọn để vô hiệu hóa đăng nhập</div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-save me-1"></i>Cập nhật
                        </button>
                        <a asp-action="ChangePassword" asp-route-id="@Model.Id"
                           class="btn btn-outline-warning">
                            <i class="bi bi-key me-1"></i>Đổi mật khẩu
                        </a>
                        <a asp-action="Index" class="btn btn-outline-secondary">Hủy</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
    <script>
        const roleSelect    = document.getElementById('roleSelect');
        const playerSection = document.getElementById('playerSection');
        function updateRole() {
            playerSection.style.display = roleSelect.value === 'Player' ? 'block' : 'none';
        }
        roleSelect.addEventListener('change', updateRole);
        updateRole();
    </script>
}
