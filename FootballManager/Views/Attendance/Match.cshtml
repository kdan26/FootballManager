@model FootballManager.ViewModels.MatchAttendanceViewModel
@using FootballManager.Models
@{
    ViewData["Title"] = "Điểm danh";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4><i class="bi bi-clipboard-check me-2 text-success"></i>Điểm danh — @Model.TeamName</h4>
    <a asp-controller="Match" asp-action="Details" asp-route-id="@Model.MatchId"
       class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Quay lại trận đấu
    </a>
</div>

<div class="card mb-3">
    <div class="card-body py-2">
        <div class="d-flex align-items-center gap-3 flex-wrap">
            <span class="fw-semibold">@Model.HomeTeamName vs @Model.AwayTeamName</span>
            <span class="text-muted">@Model.MatchDate.ToString("dd/MM/yyyy HH:mm")</span>
            <div class="ms-auto d-flex gap-2">
                <span class="badge bg-success">Có mặt: @Model.PresentCount</span>
                <span class="badge bg-danger">Vắng: @Model.AbsentCount</span>
                <span class="badge bg-warning text-dark">Chấn thương: @Model.InjuredCount</span>
                <span class="badge bg-secondary">Chưa xác nhận: @Model.UnknownCount</span>
            </div>
        </div>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (!Model.Players.Any())
{
    <div class="alert alert-warning">
        <i class="bi bi-exclamation-triangle me-2"></i>
        Đội <strong>@Model.TeamName</strong> chưa có cầu thủ nào.
        <a asp-controller="Player" asp-action="Create" asp-route-teamId="@Model.TeamId">Thêm cầu thủ</a>
    </div>
}
else
{
    <form asp-action="Save" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="MatchId" value="@Model.MatchId" />
        <input type="hidden" name="TeamId" value="@Model.TeamId" />

        <div class="card">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th style="width:50px">#</th>
                            <th>Cầu thủ</th>
                            <th>Vị trí</th>
                            <th style="width:220px">Trạng thái</th>
                            <th>Ghi chú</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < Model.Players.Count; i++)
                        {
                            var p = Model.Players[i];
                            <tr>
                                <td>
                                    <input type="hidden" name="Players[@i].PlayerId" value="@p.PlayerId" />
                                    <span class="badge bg-success">@(p.JerseyNumber?.ToString() ?? "?")</span>
                                </td>
                                <td class="fw-semibold">@p.FullName</td>
                                <td class="text-muted small">@p.PositionLabel</td>
                                <td>
                                    <select name="Players[@i].Status" class="form-select form-select-sm"
                                            data-selected="@p.Status">
                                        <option value="Unknown">Chưa xác nhận</option>
                                        <option value="Present">✅ Có mặt</option>
                                        <option value="Absent">❌ Vắng mặt</option>
                                        <option value="Injured">🤕 Chấn thương</option>
                                    </select>
                                </td>
                                <td>
                                    <input type="text" name="Players[@i].Note" value="@p.Note"
                                           class="form-control form-control-sm" placeholder="Ghi chú..." />
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        @if (User.IsInRole("Admin") || User.IsInRole("Coach"))
        {
            <div class="mt-3">
                <button type="submit" class="btn btn-success">
                    <i class="bi bi-save me-1"></i>Lưu điểm danh
                </button>
            </div>
        }
    </form>
}

@section Scripts {
<script>
    // Set selected value cho từng dropdown dựa trên data-value
    document.querySelectorAll('select[data-selected]').forEach(function(sel) {
        sel.value = sel.getAttribute('data-selected');
    });
</script>
}
