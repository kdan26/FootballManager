@using FootballManager.ViewModels
@{
    ViewData["Title"] = "Lịch thi đấu & tập luyện";
    var teams = ViewBag.Teams as List<TeamListItemViewModel> ?? new();
    int? selectedTeamId = ViewBag.TeamId as int?;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <span class="fs-5 fw-semibold">
        <i class="bi bi-calendar3 me-2 text-primary"></i>Lịch thi đấu & tập luyện
    </span>
    @if (User.IsInRole("Admin") || User.IsInRole("Coach"))
    {
        <a asp-controller="TrainingSession" asp-action="Create"
           asp-route-teamId="@selectedTeamId"
           class="btn btn-success btn-sm">
            <i class="bi bi-plus-lg me-1"></i>Thêm buổi tập
        </a>
    }
</div>

@* Bộ lọc đội *@
<div class="card mb-3">
    <div class="card-body py-2">
        <form method="get" class="row g-2 align-items-center">
            <div class="col-auto">
                <label class="form-label fw-semibold mb-0 me-2">Đội:</label>
            </div>
            <div class="col-md-3">
                <select name="teamId" class="form-select form-select-sm" onchange="this.form.submit()">
                    <option value="">-- Tất cả đội --</option>
                    @foreach (var t in teams)
                    {
                        <option value="@t.Id" selected="@(selectedTeamId == t.Id ? "selected" : null)">
                            @t.Name
                        </option>
                    }
                </select>
            </div>
            <div class="col-auto ms-3 d-flex gap-3 small">
                <span><span class="badge bg-primary">&nbsp;</span> Buổi tập</span>
                <span><span class="badge bg-success">&nbsp;</span> Đã xong</span>
                <span><span class="badge bg-danger">&nbsp;</span> Trận đấu</span>
                <span><span class="badge bg-warning text-dark">&nbsp;</span> Trận đã kết thúc</span>
            </div>
        </form>
    </div>
</div>

@* FullCalendar container *@
<div class="card">
    <div class="card-body">
        <div id="calendar"></div>
    </div>
</div>

@section Scripts {
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.15/index.global.min.css" />
<script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.15/index.global.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.15/locales/vi.global.min.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function () {
    const teamId = @Html.Raw(selectedTeamId.HasValue ? selectedTeamId.Value.ToString() : "null");

    const calendar = new FullCalendar.Calendar(document.getElementById('calendar'), {
        locale: 'vi',
        initialView: 'dayGridMonth',
        headerToolbar: {
            left:   'prev,next today',
            center: 'title',
            right:  'dayGridMonth,timeGridWeek,listWeek'
        },
        height: 680,
        navLinks: true,
        eventDisplay: 'block',
        eventDidMount: function(info) {
            // Tooltip khi hover
            info.el.setAttribute('title', info.event.extendedProps.statusLabel || info.event.title);
        },
        events: function(fetchInfo, successCallback, failureCallback) {
            const params = new URLSearchParams({
                start: fetchInfo.startStr.substring(0, 10),
                end:   fetchInfo.endStr.substring(0, 10)
            });
            if (teamId) params.append('teamId', teamId);

            fetch(`/Calendar/Events?${params}`)
                .then(r => r.json())
                .then(data => {
                    successCallback(data.map(e => ({
                        id:    e.type + '_' + e.id,
                        title: e.title,
                        start: e.start,
                        end:   e.end,
                        color: e.color,
                        url:   e.url,
                        extendedProps: { statusLabel: e.statusLabel, type: e.type }
                    })));
                })
                .catch(failureCallback);
        },
        eventClick: function(info) {
            info.jsEvent.preventDefault();
            if (info.event.url) window.location.href = info.event.url;
        }
    });

    calendar.render();
});
</script>
}
